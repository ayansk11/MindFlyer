# ─────────────────────────────────────────────────────────────────────────────
# MindFlyer Frontend — Environment Variables
# Copy to .env.local:  cp .env.example .env.local
#
# NOTE: Only PUBLIC keys go here. Secret API keys (Claude, Hume, Deepgram,
# Supermemory) live in backend/.env — the frontend calls /api/* proxy.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — public config (secure via Firebase security rules)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
